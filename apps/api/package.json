{
  "name": "@math/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.development.example --env-file-if-exists=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "db:migrate": "tsx --env-file=.env.development.example --env-file-if-exists=.env src/db/migrate.ts",
    "seed:admin": "tsx --env-file=.env.development.example --env-file-if-exists=.env src/auth/seed-admin.ts",
    "serve:web": "tsx --env-file=.env.development.example --env-file-if-exists=.env src/serve-web.ts"
  },
  "dependencies": {
    "@hono/node-server": "latest",
    "@math/shared": "*",
    "better-auth": "latest",
    "drizzle-orm": "latest",
    "hono": "latest",
    "postgres": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "drizzle-kit": "latest",
    "tsx": "latest"
  }
}
