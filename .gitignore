.DS_Store

# Dependencies
node_modules/
apps/*/node_modules/
packages/*/node_modules/

# Build outputs
dist/
apps/*/dist/
packages/*/dist/

# Local environment files
.env
.env.*
!.env.example
!.env.development.example
apps/*/.env
apps/*/.env.*
