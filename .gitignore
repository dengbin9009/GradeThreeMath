coverage/
test-results/
playwright-report/
blob-report/
*.lcov

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.temp

# Local editor state
.idea/
.vscode/
