{
  "name": "shanghai-grade3-math-blueprint",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm run dev -w @math/api\" \"npm run dev -w @math/web\"",
    "build": "npm run build -w @math/shared && npm run build -w @math/api && npm run build -w @math/web",
    "preview": "npm run preview -w @math/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "db:migrate": "npm run db:migrate -w @math/api",
    "seed:admin": "npm run seed:admin -w @math/api"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@rolldown/binding-darwin-arm64": "^1.1.2",
    "@types/node": "^26.0.0",
    "concurrently": "^9.2.3",
    "eslint": "latest",
    "eslint-plugin-vue": "latest",
    "globals": "latest",
    "hono": "latest",
    "jsdom": "^29.1.1",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest",
    "vue": "^3.5.38",
    "vue-eslint-parser": "^10.4.1"
  }
}
